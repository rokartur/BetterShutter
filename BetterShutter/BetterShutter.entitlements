<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Not sandboxed: BetterUpdater replaces the app bundle in place, which the
	     App Sandbox forbids. Distribute outside the Mac App Store (Developer ID
	     + notarization). Add com.apple.security.* exceptions here as needed. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
